# ── MongoDB Connection ───────────────────────────────────────
# Priority 1: Full URI (overrides individual components below)
# Production: mongodb+srv://user:pass@cluster.mongodb.net/
# MONGO_URI=mongodb://mongo_db:27017/

# Priority 2: Individual components (used when MONGO_URI is unset)
MONGO_HOST=mongo_db          # Docker service name; use 127.0.0.1 for local dev
MONGO_PORT=27017
MONGO_DB_NAME=dealershipsDB

# ── Database Seeding ─────────────────────────────────────────
# Set to "true" to purge and re-seed from data/*.json on startup.
# Disable in stateless cloud deployments to skip local file reads.
SEED_DATABASE=true

# ── Data Directory ───────────────────────────────────────────
# Path to the folder containing data/dealerships.json and data/reviews.json.
# Defaults to __dirname (the directory of app.js).
# DATA_DIR=/app
